	<!--<img src="images/plant_border2.png" left="1" top="3" width="38" height="22" style="dithering">-->
	
   	<div name="banner" left="10" top="1" width="32" height="24">
   		<row> __  __   _  ___          _</row>
	    <row>|  \/  | | |/ (_)_      _(_)</row>
	    <row>| |\/| |-| ' /| \ \ /\ / / |</row>
